			</trans-unit>
			<trans-unit id="tx_news_domain_model_news.recurring_time_ranges.add">
				<source>Add time range</source>
				<target>Zeitbereich hinzufügen</target>
			</trans-unit>
			<trans-unit id="tx_news_domain_model_news.recurring_time_ranges.remove">
				<source>Remove time range</source>
				<target>Zeitbereich entfernen</target>
			</trans-unit>
			<trans-unit id="tx_news_domain_model_news.recurring_time_ranges.from">
				<source>From</source>
				<target>Von</target>
			</trans-unit>
			<trans-unit id="tx_news_domain_model_news.recurring_time_ranges.to">
				<source>To</source>
				<target>Bis</target>
			</trans-unit>
      <trans-unit id="palette.recurring_settings">
				<source>Recurrence Settings</source>
				<target>Wiederholungseinstellungen</target>
			</trans-unit>
			<trans-unit id="tx_news_domain_model_news.recurring_exclude_school_holidays">
				<source>Exclude school holidays</source>
				<target>Schulferien ausschließen</target>
			</trans-unit>
			<trans-unit id="tx_news_domain_model_news.recurring_exclude_public_holidays">
				<source>Exclude public holidays</source>
				<target>Feiertage ausschließen</target>
			</trans-unit>
			<trans-unit id="tx_news_domain_model_news.recurring_monthly_week">
				<source>Monthly repeat mode</source>
				<target>Monatlicher Wiederholungsmodus</target>
			</trans-unit>
			<trans-unit id="tx_news_domain_model_news.recurring_monthly_week.description">
				<source>Choose whether to repeat on a fixed date or on a specific weekday within the month.</source>
				<target>Wählen Sie, ob die Veranstaltung an einem festen Datum oder an einem bestimmten Wochentag im Monat wiederholt wird.</target>
			</trans-unit>
			<trans-unit id="tx_news_domain_model_news.recurring_monthly_week.bydate">
				<source>On fixed date (e.g. every 15th)</source>
				<target>Am festen Datum (z. B. jeden 15.)</target>
			</trans-unit>
			<trans-unit id="tx_news_domain_model_news.recurring_monthly_week.first">
