{
  "name": "spielerj/eventnews-recurring",
  "version": "1.0.5",
  "type": "typo3-cms-extension",
  "description": "Adds recurring event support to georgringer/eventnews",
  "license": "GPL-2.0-or-later",
  "require": {
    "typo3/cms-core": "^13.0",
    "georgringer/news": "^12.0",
    "georgringer/eventnews": "^7.0",
    "rlanvin/php-rrule": "^2.6"
  },
  "autoload": {
    "psr-4": {
      "Spielerj\\EventnewsRecurring\\": "Classes/"
    }
  },
  "extra": {
    "typo3/cms": {
      "extension-key": "eventnews_recurring"
    }
  },
  "config": {
    "allow-plugins": {
      "typo3/cms-composer-installers": true,
      "typo3/class-alias-loader": true
    }
  }
}
